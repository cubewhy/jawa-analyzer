SOURCE:
package com.example;

import java.util.ArrayList;

class Test {
    java.util.List<java.lang.String> test() {
        java.util.List<java.lang.String> l = new ArrayList<>();
        l.add(new com.example.Test().toString());

        return l;
    }
}

